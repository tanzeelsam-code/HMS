{
  "name": "nexushos",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite",
    "server": "node server/index.js",
    "build": "tsc && vite build",
    "preview": "npm run build && wrangler dev",
    "test": "node --test --test-concurrency=1",
    "backup": "node scripts/backup.mjs",
    "backup:verify": "node scripts/verify-backup.mjs",
    "migrate:sqlite": "node scripts/migrate-sqlite-to-postgres.mjs",
    "bootstrap:admin": "node scripts/bootstrap-admin.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "express": "^5.2.1",
    "lucide-react": "^0.469.0",
    "pg": "8.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.46.0",
    "@electric-sql/pglite": "0.5.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wrangler": "^4.113.0"
  }
}
