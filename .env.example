# Local runtime
NODE_ENV=development
PORT=4000
HMS_DB_PATH=server/hms.db
HMS_TIME_ZONE=Europe/Copenhagen
HMS_CURRENCY=USD
HMS_TAX_RATE=0.12
HMS_ALLOWED_ORIGINS=http://localhost:3000
HMS_BACKUP_DIR=backups
# Set only to an explicit ingress hop count (1-5) or trusted IP/CIDR list.
# HMS_TRUST_PROXY=127.0.0.1,10.0.0.0/8

# Production secrets: use a secret manager and rotate them regularly.
NEXUSHOS_AUDIT_HMAC_SECRET=replace-with-at-least-32-random-bytes
NEXUSHOS_WEBHOOK_ENCRYPTION_KEY=replace-with-at-least-32-random-bytes
NEXUSHOS_RATE_LIMIT_PEPPER=replace-with-a-long-random-secret
NEXUSHOS_DELIVERY_WORKER_ENABLED=false
NEXUSHOS_DELIVERY_WORKER_INTERVAL_MS=5000

# One-use inputs for `NODE_ENV=production npm run bootstrap:admin` on a new DB.
# Remove them from the runtime environment immediately after bootstrap.
NEXUSHOS_BOOTSTRAP_ADMIN_EMAIL=owner@example.com
NEXUSHOS_BOOTSTRAP_ADMIN_NAME=Initial General Manager
NEXUSHOS_BOOTSTRAP_ADMIN_PASSWORD=replace-through-a-secret-manager
NEXUSHOS_BOOTSTRAP_PROPERTY_NAME=Example Hotel
NEXUSHOS_BOOTSTRAP_PROPERTY_CODE=EXH
NEXUSHOS_BOOTSTRAP_PROPERTY_TIMEZONE=Europe/Copenhagen
NEXUSHOS_BOOTSTRAP_PROPERTY_CURRENCY=DKK
NEXUSHOS_BOOTSTRAP_PROPERTY_ROOMS=100

# Webhook safety overrides are intended only for controlled local testing.
NEXUSHOS_WEBHOOK_ALLOW_PRIVATE_NETWORKS=false
NEXUSHOS_WEBHOOK_ALLOW_INSECURE_HTTP=false
